{
  "name": "specimen-sandbox",
  "license": "0BSD",
  "main": "expo-router/entry",
  "version": "1.2.0",
  "scripts": {
    "start": "expo start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "db:compile": "node scripts/compile_species_db.mjs",
    "db:smoke": "node scripts/db-smoke.mjs",
    "screenshots:capture": "node scripts/capture_screenshots.mjs",
    "screenshots:capture:auto": "node scripts/capture_screenshots_auto.mjs",
    "screenshots:verify": "node scripts/verify_screenshots.mjs",
    "e2e": "maestro test .maestro/",
    "e2e:smoke": "maestro test .maestro/smoke.yml",
    "deploy:ios": "eas submit --platform ios --profile production --non-interactive",
    "deploy:android": "eas submit --platform android --profile production --non-interactive"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.11",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/native": "^7.0.14",
    "expo": "~56.0.3",
    "expo-asset": "~56.0.13",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-file-system": "~56.0.7",
    "expo-image": "~56.0.8",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-location": "~56.0.12",
    "expo-router": "~56.2.5",
    "expo-splash-screen": "~56.0.9",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.15",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-flip-card": "^3.5.7",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "volta": {
    "node": "22.18.0",
    "pnpm": "11.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/react": "~19.2.0",
    "jimp": "^1.6.1",
    "typescript": "^6.0.0"
  }
}