{
  "expo": {
    "name": "Sandbox Playing Flowers",
    "slug": "playing-in-the-sandox-looking-at-flowers",
    "version": "1.0.0",
    "privacy": "public",
    "description": "An interactive flower gallery with beautiful animations and seasonal collections. Flip through various flower types with immersive haptic feedback.",
    "primaryColor": "#4CAF50",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djscottyb.playinginthesandoxlookingatflowers",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.entertainment",
        "CFBundleLocalizations": ["en"],
        "UIRequiredDeviceCapabilities": ["arm64"],
        "UIBackgroundModes": [],
        "UIViewControllerBasedStatusBarAppearance": true
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [],
      "primaryCategory": "Entertainment",
      "secondaryCategory": "Education"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.djscottyb.playinginthesandoxlookingatflowers",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Sandbox Flowers",
      "shortName": "Sandbox Flowers",
      "description": "Creative expression in a digital sandbox",
      "themeColor": "#ffffff",
      "lang": "en-US"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ce77dd42-8e41-4320-8eb3-6b96b801b3b6"
      },
      "encryptionDocPath": "./ENCRYPTION_NOTICE.md",
      "dsaCompliancePath": "./DSA_COMPLIANCE.md"
    },
    "owner": "djscottyb",
    "updates": {
      "url": "https://u.expo.dev/ce77dd42-8e41-4320-8eb3-6b96b801b3b6"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "jsEngine": "hermes",
    "locales": {
      "en": "./assets/locales/en.json"
    },
    "platforms": ["ios", "android", "web"],
    "githubUrl": "https://github.com/TheScottyB/playing-in-the-sandox-looking-at-flowers",
    "contentRating": ["4+", "everyone"]
  }
}
