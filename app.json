{
  "expo": {
    "name": "Playing in the Sandox looking at Flowers",
    "slug": "playing-in-the-sandox-looking-at-flowers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djscottyb.playinginthesandoxlookingatflowers"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.djscottyb.playinginthesandoxlookingatflowers"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ce77dd42-8e41-4320-8eb3-6b96b801b3b6"
      }
    },
    "owner": "djscottyb",
    "updates": {
      "url": "https://u.expo.dev/ce77dd42-8e41-4320-8eb3-6b96b801b3b6"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
