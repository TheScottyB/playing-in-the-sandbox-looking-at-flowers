{
  "expo": {
    "name": "Sandbox Playing Flowers",
    "slug": "playing-in-the-sandox-looking-at-flowers",
    "version": "1.1.1",
    "description": "Wake up to a fresh AI-generated image of a native flower blooming near you today. Every morning, a new picture — matched to your US state and the current season.",
    "primaryColor": "#4CAF50",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sandbox-flowers",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djscottyb.playinginthesandoxlookingatflowers",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.entertainment",
        "CFBundleLocalizations": ["en"],
        "UIRequiredDeviceCapabilities": ["arm64"],
        "NSLocationWhenInUseUsageDescription": "Your region is used once to show flowers native to your area. It is never shared.",
        "UIBackgroundModes": [],
        "UIViewControllerBasedStatusBarAppearance": true
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.djscottyb.playinginthesandoxlookingatflowers",
      "versionCode": 1,
      "permissions": ["INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Sandbox Flowers",
      "shortName": "Sandbox Flowers",
      "description": "Wake up to a fresh AI-generated image of a native flower blooming near you today.",
      "themeColor": "#ffffff",
      "lang": "en-US"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your region is used once to show flowers native to your area. It is never shared."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4CAF50"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ce77dd42-8e41-4320-8eb3-6b96b801b3b6"
      },
      "encryptionDocPath": "./ENCRYPTION_NOTICE.md",
      "dsaCompliancePath": "./DSA_COMPLIANCE.md",
      "privacyPolicyUrl": "https://thescottyb.github.io/playing-in-the-sandox-looking-at-flowers/privacy.html",
      "supportUrl": "https://github.com/TheScottyB/playing-in-the-sandbox-looking-at-flowers/issues",
      "appStore": {
        "primaryCategory": "Entertainment",
        "secondaryCategory": "Lifestyle",
        "contentRating": ["4+", "everyone"]
      }
    },
    "owner": "thescottybe",
    "updates": {
      "url": "https://u.expo.dev/ce77dd42-8e41-4320-8eb3-6b96b801b3b6"
    },
    "runtimeVersion": "1.1.1",
    "locales": {
      "en": "./assets/locales/en.json"
    },
    "platforms": ["ios", "android", "web"],
    "githubUrl": "https://github.com/TheScottyB/playing-in-the-sandox-looking-at-flowers"
  }
}
