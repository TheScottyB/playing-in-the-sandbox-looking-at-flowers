{
  "expo": {
    "name": "Specimen Sandbox",
    "slug": "playing-in-the-sandbox-staring-at-flowers",
    "version": "1.1.1",
    "description": "Wake up to a fresh AI-generated image of a native flower blooming near you today. Every morning, a new picture — matched to your US state and the current season.",
    "primaryColor": "#0a0a0c",
    "orientation": "portrait",
    "icon": "./app_store_assets/icons/icon-1024.png",
    "scheme": "staring-at-flowers",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djscottyb.playinginthesandoxlookingatflowers",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationCategoryType": "public.app-category.entertainment",
        "CFBundleLocalizations": [
          "en"
        ],
        "UIRequiredDeviceCapabilities": [
          "arm64"
        ],
        "NSLocationWhenInUseUsageDescription": "Your region is used once to show flowers native to your area. It is never shared.",
        "UIBackgroundModes": [],
        "UIViewControllerBasedStatusBarAppearance": true
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app_store_assets/icons/adaptive-foreground.png",
        "backgroundImage": "./app_store_assets/icons/adaptive-background.png",
        "monochromeImage": "./app_store_assets/icons/monochrome.png",
        "backgroundColor": "#0a0a0c"
      },
      "package": "com.djscottyb.playinginthesandoxlookingatflowers",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Specimen Sandbox",
      "shortName": "Staring at Flowers",
      "description": "Wake up to a fresh AI-generated image of a native flower blooming near you today.",
      "themeColor": "#0a0a0c",
      "lang": "en-US"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your region is used once to show flowers native to your area. It is never shared."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./app_store_assets/icons/adaptive-foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0c"
        }
      ],
      ["expo-image", { "disableLibdav1d": true }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "e8192c1a-82b3-4aa0-bca3-65437def1fc6"
      },
      "encryptionDocPath": "./ENCRYPTION_NOTICE.md",
      "dsaCompliancePath": "./DSA_COMPLIANCE.md",
      "privacyPolicyUrl": "https://thescottyb.github.io/playing-in-the-sandbox-staring-at-flowers/privacy.html",
      "supportUrl": "https://github.com/TheScottyB/playing-in-the-sandbox-staring-at-flowers/issues",
      "appStore": {
        "primaryCategory": "Entertainment",
        "secondaryCategory": "Lifestyle",
        "contentRating": ["4+", "everyone"]
      },
      "router": {}
    },
    "owner": "thescottybe",
    "runtimeVersion": "1.1.1",
    "locales": {
      "en": "./assets/locales/en.json"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "githubUrl": "https://github.com/TheScottyB/playing-in-the-sandbox-staring-at-flowers",
    "updates": {
      "url": "https://u.expo.dev/e8192c1a-82b3-4aa0-bca3-65437def1fc6"
    }
  }
}
