{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/constants/*": [
        "./shared/constants/*"
      ],
      "@/components/*": [
        "./shared/components/*"
      ],
      "@/styles/*": [
        "./shared/styles/*"
      ],
      "@/types/*": [
        "./shared/types/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
